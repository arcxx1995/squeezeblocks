{
  "private": true,
  "name": "squeezeblocks",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && npm run lint && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test": "node --no-warnings --experimental-loader ./tests/loader.mjs ./tests/flow.test.mjs && node --no-warnings --experimental-loader ./tests/loader.mjs ./tests/notify.test.mjs && node --no-warnings --experimental-loader ./tests/loader.mjs ./tests/daily.test.mjs && node --no-warnings --experimental-loader ./tests/loader.mjs ./tests/elo.test.mjs",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.6",
    "@devvit/web": "0.13.6",
    "@hono/node-server": "2.0.6",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "devvit": "0.13.6",
    "hono": "4.12.27",
    "phaser": "4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "10.4.1",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.1.0"
  }
}
