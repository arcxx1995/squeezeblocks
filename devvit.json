{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "squeezeblocks",
  "permissions": {
    "redis": true,
    "realtime": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "New squeezeblocks game",
        "description": "Start a dots & boxes match",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Pin squeezeblocks daily challenge",
        "description": "Create and sticky the daily challenge post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/daily-create"
      },
      {
        "label": "Delete all squeezeblocks posts",
        "description": "Remove every post in this subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/delete-all"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "sweep": {
        "endpoint": "/internal/scheduler/sweep",
        "cron": "*/30 * * * * *"
      },
      "daily-post": {
        "endpoint": "/internal/scheduler/daily",
        "cron": "0 0 0 * * *"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "squeezeblocks_dev"
  }
}